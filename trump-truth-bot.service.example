[Unit]
Description=Trump Truth Telegram Bot
After=network.target

[Service]
Type=simple
WorkingDirectory=/path/to/trump-truth-bot
Environment=RUN_MODE=daemon
ExecStart=/home/ubuntu/nvm/versions/node/v24.14.0/bin/node /path/to/trump-truth-bot/src/index.js
Restart=always
RestartSec=5
User=ubuntu

[Install]
WantedBy=multi-user.target
